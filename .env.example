# =============================================================================
# Puppy Stardew Server Configuration
# 小狗星谷服务器配置
# =============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and fill in your Steam credentials below
# 3. Run: docker compose up -d
#
# 快速开始：
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 并在下方填写您的 Steam 凭证
# 3. 运行：docker compose up -d
#
# =============================================================================

# =============================================================================
# Steam Credentials (REQUIRED) | Steam 凭证（必需）
# =============================================================================
# IMPORTANT: You MUST own Stardew Valley on Steam!
# 重要：您必须在 Steam 上拥有星露谷物语！
#
# Game files will be downloaded via your Steam account during first startup.
# 游戏文件将在首次启动时通过您的 Steam 账户下载。
#
# Your credentials are stored locally and NEVER sent anywhere except to Steam.
# 您的凭证仅存储在本地，除了 Steam 之外不会发送到任何地方。
# =============================================================================

# Your Steam username (NOT email, unless you use email to login)
# 您的 Steam 用户名（除非您使用邮箱登录，否则不是邮箱）
STEAM_USERNAME=your_steam_username

# Your Steam password
# 您的 Steam 密码
STEAM_PASSWORD=your_steam_password

# NOTE: For better security, you can use Docker Secrets instead.
# 注意：为了更好的安全性，您可以使用 Docker Secrets 代替。
# See docker-compose.yml for setup instructions.
# Alternative JSON secret file:
#   mkdir -p data/secrets
#   printf '{"username":"your_steam_username","password":"your_steam_password"}\n' > data/secrets/steam.json
#   chmod 600 data/secrets/steam.json
# STEAM_JSON_SECRET=/home/steam/secrets/steam.json
# Recommended for passwords containing $, #, spaces, quotes, or backslashes.
# One-click setup writes Steam credentials to data/secrets/steam.json for this reason.
# 如果 Steam 密码包含 $, #, 空格、引号或反斜杠，推荐使用 data/secrets/steam.json。
# 一键安装脚本会默认把 Steam 凭据写入该 secret 文件，避免 .env 被 Docker Compose 误解析。
# 参见 docker-compose.yml 中的设置说明。

# =============================================================================
# VNC Settings (OPTIONAL) | VNC 设置（可选）
# =============================================================================
# VNC is used for initial setup to create/load a save file.
# VNC 用于初始设置以创建/加载存档文件。
#
# After setup, you can disable VNC to save ~50MB RAM:
# 设置完成后，您可以禁用 VNC 以节省约 50MB 内存：
#   Set ENABLE_VNC=false and restart: docker compose up -d
#   设置 ENABLE_VNC=false 并重启：docker compose up -d
# =============================================================================

# Enable VNC remote access (true/false)
# 启用 VNC 远程访问（true/false）
ENABLE_VNC=true

# VNC password (max 8 characters due to VNC protocol limitation)
# VNC 密码（VNC 协议限制最多 8 个字符）
#
# ⚠️ IMPORTANT: Password will be truncated to 8 characters by VNC!
# ⚠️ 重要：VNC 会自动截断密码为 8 个字符！
#
# SECURITY: Leave this blank to auto-generate a random password at startup.
# The effective password is written to web-panel/data/vnc_password.txt inside
# the container (retrieve with: docker exec <container> cat /home/steam/web-panel/data/vnc_password.txt).
# Set your own value here only if you need a fixed password.
# 安全：留空则启动时自动生成随机密码，密码写入容器内 web-panel/data/vnc_password.txt
# （用 docker exec <容器> cat /home/steam/web-panel/data/vnc_password.txt 读取）。
# 仅当你需要固定密码时才在此填写。
VNC_PASSWORD=

# =============================================================================
# Web Management Panel (OPTIONAL) | Web 管理面板（可选）
# =============================================================================
# Browser-based control panel: http://your-server-ip:18642
# 浏览器控制面板：http://你的服务器IP:18642
#
# On first visit, the panel will prompt you to create an admin password.
# 首次访问时，面板会提示您创建管理密码。

# =============================================================================
# Advanced Options (OPTIONAL) | 高级选项（可选）
# =============================================================================
# Most users don't need to change these settings.
# 大多数用户不需要更改这些设置。
# =============================================================================

# Docker build base images / Docker 构建基础镜像
# Keep defaults unless your server cannot reach Docker Hub.
# 如果服务器访问 Docker Hub 很慢或超时，可以改成服务器商提供的镜像源地址。
# Example:
# MANAGER_BASE_IMAGE=your-mirror.example.com/docker:27-cli
# SERVER_BASE_IMAGE=your-mirror.example.com/ubuntu:22.04
# MANAGER_BASE_IMAGE=docker:27-cli
# SERVER_BASE_IMAGE=ubuntu:22.04

# GPU rendering (default: false)
# GPU 渲染（默认：禁用）
#
# Enable GPU hardware acceleration to reduce CPU usage.
# 启用 GPU 硬件加速以降低 CPU 占用。
#
# Requirements: Host must have /dev/dri and docker-compose.yml must map it.
# 要求：宿主机必须有 /dev/dri 且 docker-compose.yml 需映射该设备。
#
# Set to true to use Xorg with GPU, false to use Xvfb (software rendering).
# 设置为 true 使用 Xorg + GPU，false 使用 Xvfb（软件渲染）。
# USE_GPU=false

# Display resolution (default: 1280x720@60Hz)
# 显示分辨率（默认：1280x720@60Hz）
#
# Adjust if needed for your VNC client or display requirements.
# 如需调整 VNC 客户端或显示需求，可修改此设置。
# RESOLUTION_WIDTH=1280
# RESOLUTION_HEIGHT=720
# REFRESH_RATE=60

# Performance optimization / 性能优化
# 性能较弱的机器可启用低性能模式以降低 Xvfb 分辨率、色深和渲染负载。
# LOW_PERF_MODE=true
# TARGET_FPS=30

# Web panel tuning for 2C/2G servers / 2核2G 面板轻量配置
# These defaults reduce disk reads, hashing frequency, command wait time and
# in-memory history size while keeping dashboard/player refresh at 20 seconds.
# 这些默认值会减少读盘、哈希、命令等待时间和内存历史记录，同时保留 20 秒状态刷新。
# PANEL_STATUS_CACHE_MS=5000
# PANEL_STATUS_HISTORY_LIMIT=180
# PANEL_STATUS_LOG_TAIL_BYTES=131072
# PANEL_WORLD_STATE_CACHE_MS=60000
# PANEL_WORLD_HASH_MODE=manifest
# PANEL_PLAYER_HISTORY_LIMIT=144
# PANEL_PLAYER_LOG_TAIL_BYTES=131072
# PANEL_LOG_TAIL_BYTES=524288
# PANEL_LOG_DEFAULT_LINES=200
# PANEL_LOG_MAX_LINES=600
# PANEL_PUBLIC_MOD_MANIFEST_CACHE_MS=120000
# PANEL_MOD_EXTRACT_TIMEOUT_MS=120000
# PANEL_DIAGNOSTIC_LOG_TAIL_BYTES=262144
# PANEL_HEALTH_COMMAND_TIMEOUT_MS=1500
# PANEL_COMMAND_TIMEOUT_MS=1500

# Server timezone (default: UTC)
# 服务器时区（默认：UTC）
# Examples: America/New_York, Europe/London, Asia/Shanghai
# 示例：America/New_York, Europe/London, Asia/Shanghai
# TZ=UTC

# Log monitoring (default: true)
# 日志监控（默认：启用）
#
# Automatically monitors and categorizes game logs.
# 自动监控并分类游戏日志。
# Logs are rotated every 6 hours to prevent disk bloat.
# 日志每6小时轮转一次以防止磁盘占用过大。
#
# Retention: 7 days (detailed) + 30 days (compressed archives)
# 保留期：7天（详细日志）+ 30天（压缩归档）
#
# Set to false to disable log management (saves ~10MB RAM)
# 设置为 false 可禁用日志管理（节省约 10MB 内存）
ENABLE_LOG_MONITOR=true

# Auto-backup (default: false)
# 自动备份（默认：禁用）
#
# Automatically backs up save files daily at configured hour.
# 在配置的时间每天自动备份存档文件。
#
# Backups are stored in data/backups/ and kept for MAX_BACKUPS days.
# 备份存储在 data/backups/ 并保留 MAX_BACKUPS 天。
#
# ENABLE_AUTO_BACKUP=true
# MAX_BACKUPS=7
# BACKUP_HOUR=4
# BACKUP_COMPRESSION_LEVEL=1

# Crash auto-restart (default: false)
# 崩溃自动重启（默认：禁用）
#
# Automatically restarts game if it crashes.
# 游戏崩溃时自动重启。
#
# Max restarts: 5 times per 5 minutes to prevent restart loops.
# 最大重启次数：5分钟内5次，防止重启循环。
#
# ENABLE_CRASH_RESTART=true
# MAX_CRASH_RESTARTS=5

# Prometheus metrics (default: enabled on port 9090)
# Prometheus 指标（默认：在端口 9090 启用）
#
# Exposes metrics at http://your-server:9090/metrics
# 指标暴露在 http://your-server:9090/metrics
#
# Metrics include: player count, uptime, CPU/memory, event counts.
# 指标包括：玩家数量、运行时间、CPU/内存、事件计数。
#
# METRICS_PORT=9090

# Log monitor tuning (default: enabled, 5s interval)
# ENABLE_LOG_MONITOR=true
# LOG_MONITOR_INTERVAL=5
# LOG_MONITOR_BATCH_SIZE=500

# Keep false unless you specifically need keyboard fallback for 2AM passout.
# 保持 false，避免把玩家野外晕倒误判成凌晨2点过夜并乱按键。
# ENABLE_PASSOUT_KEY_AUTOMATION=false

# Manual game-time pause control file used by the web panel and AutoHideHost.
# 面板和 AutoHideHost 共用的手动暂停游戏时间控制文件。
# MANUAL_PAUSE_FILE=/home/steam/web-panel/data/manual-pause.json

# Automatic empty-server pause control file used by the web panel and AutoHideHost.
# 面板和 AutoHideHost 共用的自动空服暂停控制文件。
# AUTO_PAUSE_FILE=/home/steam/web-panel/data/auto-pause.json

# SMAPI authoritative game-state bridge written by AutoHideHost.
# AutoHideHost 写出的 SMAPI 权威状态桥，面板用它判断存档/联机/可加入状态。
# GAME_STATE_FILE=/home/steam/web-panel/data/game-state.json

# Host-control command file used when the panel asks AutoHideHost to show/hide the server host.
# 面板请求 AutoHideHost 显示/隐藏服务器房主时使用的控制文件，避免直接写 /proc stdin 被权限拒绝。
# HOST_COMMAND_FILE=/home/steam/web-panel/data/host-command.json
#
# Architecture v2 metadata files.
# PUPPY_META_DIR=/home/steam/web-panel/data/meta
# ORCHESTRATION_STATE_FILE=/home/steam/web-panel/data/meta/orchestration-state.json
# MOD_GRAPH_FILE=/home/steam/web-panel/data/meta/mod_graph.json
# WORLD_FINGERPRINT_FILE=/home/steam/web-panel/data/meta/world_fingerprint.json

# Public join IP shown in the dashboard (optional)
# 仪表盘显示的公网联机 IP（可选）
#
# Set this if players join over the internet and you want the panel
# to show your public IP/domain instead of the container LAN IP.
# 如果玩家通过公网联机，建议设置它，这样仪表盘会优先显示公网 IP 或域名，
# 而不是容器内网地址。
# PUBLIC_IP=your.public.ip.or.domain

# Maximum displayed and preferred Stardew co-op player limit.
# 面板显示和游戏启动偏好使用的联机人数上限。
# MAX_PLAYERS=8

# =============================================================================
# Troubleshooting | 故障排除
# =============================================================================
#
# Problem: "Disk write failure" when downloading game
# 问题：下载游戏时出现 "Disk write failure"
#
# Solution: Fix data directory permissions
# 解决方法：修复数据目录权限
#   mkdir -p data/{saves,game,steam}
#   chown -R 1000:1000 data/
#   docker compose restart
#
# ---
#
# Problem: Steam Guard code required
# 问题：需要 Steam 令牌代码
#
# Solution: Attach to container and enter code
# 解决方法：连接到容器并输入代码
#   docker attach puppy-stardew
#   (Enter Steam Guard code from your email/mobile app)
#   (输入来自邮箱/手机应用的 Steam 令牌代码)
#   (Press Ctrl+P Ctrl+Q to detach - NOT Ctrl+C!)
#   (按 Ctrl+P Ctrl+Q 分离 - 不是 Ctrl+C！)
#
# ---
#
# Problem: Players can't connect
# 问题：玩家无法连接
#
# Solution: Check firewall and ensure port 24642/udp is open
# 解决方法：检查防火墙并确保端口 24642/udp 已开放
#   Ubuntu/Debian: sudo ufw allow 24642/udp
#   CentOS/RHEL: sudo firewall-cmd --add-port=24642/udp --permanent
#
# ---
#
# For more help, see:
# 获取更多帮助，请查看：
#   - README.md
#   - https://github.com/AmigaMeow/puppy-stardew-server/issues
#   - Docker Hub: https://hub.docker.com/r/truemanlive/puppy-stardew-server
#
# =============================================================================
